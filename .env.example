# GID of the host "docker" group, used by compose `group_add` so the non-root
# container user can access the mounted /var/run/docker.sock.
# Linux: run `getent group docker | cut -d: -f3` and use that number (often 999).
# Docker Desktop (macOS/Windows): the mounted socket is owned by root, set this to 0.
DOCKER_GID=999

# Docker network the app and the dynamically spawned CloakBrowser container share.
BROWSER_NETWORK=cloak_net
